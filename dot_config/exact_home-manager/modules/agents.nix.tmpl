{ config, pkgs, ... }:

let
  sources = import ./sources.nix { inherit pkgs; };
in
{
  home.packages = with pkgs; [
    (pkgs.writeShellScriptBin "codex-acp" ''
      exec bunx @zed-industries/codex-acp@latest "$@"
    '')
    (pkgs.writeShellScriptBin "mcporter" ''
      exec bunx mcporter@latest "$@"
    '')
    llm-agents.agent-browser

    maestro
    antigravity
  ];

  home.file = {
    ".agents/skills/openai" = {
      source = "${sources.openai-skills}/skills";
      recursive = true;
    };
    ".agents/skills/anthropics/docx".source = "${sources.anthropics-skills}/skills/docx";
    ".agents/skills/anthropics/pptx".source = "${sources.anthropics-skills}/skills/pptx";
    ".agents/skills/anthropics/xlsx".source = "${sources.anthropics-skills}/skills/xlsx";
    ".agents/skills/anthropics/doc-coauthoring".source = "${sources.anthropics-skills}/skills/doc-coauthoring";
    ".agents/skills/anthropics/internal-comms".source = "${sources.anthropics-skills}/skills/internal-comms";
    ".agents/skills/anthropics/canvas-design".source = "${sources.anthropics-skills}/skills/canvas-design";
    ".agents/skills/anthropics/frontend-design".source = "${sources.anthropics-skills}/skills/frontend-design";
    ".agents/skills/anthropics/theme-factory".source = "${sources.anthropics-skills}/skills/theme-factory";
    ".agents/skills/anthropics/web-artifacts-builder".source = "${sources.anthropics-skills}/skills/web-artifacts-builder";
    ".agents/skills/anthropics/mcp-builder".source = "${sources.anthropics-skills}/skills/mcp-builder";
    ".agents/skills/vercel-labs/agent-browser" = {
      source = "${sources.agent-browser}/skills";
      recursive = true;
    };
    ".agents/skills/vercel-labs/agent-skills" = {
      source = "${sources.agent-skills}/skills";
      recursive = true;
    };
    ".agents/skills/vercel-labs/core" = {
      source = "${sources.vercel-skills}/skills";
      recursive = true;
    };
    ".agents/skills/remotion-dev" = {
      source = "${sources.remotion-skills}/skills";
      recursive = true;
    };
    ".agents/skills/nextlevelbuilder" = {
      source = "${sources.ui-ux-pro-max-skill}/.claude/skills";
      recursive = true;
    };
    ".agents/skills/kepano" = {
      source = "${sources.obsidian-skills}/skills";
      recursive = true;
    };
    ".agents/skills/openclaw/mcporter".source = "${sources.openclaw-skills}/skills/mcporter";
    ".agents/skills/openclaw/coding-agent".source = "${sources.openclaw-skills}/skills/coding-agent";
    ".agents/skills/obra" = {
      source = "${sources.obra-superpowers}/skills";
      recursive = true;
    };
    ".agents/skills/figma" = {
      source = "${sources.figma-mcp-server-guide}/skills";
      recursive = true;
    };
  };

  programs = {
    opencode = {
      enable = true;
      package = (pkgs.writeShellScriptBin "opencode" ''
      export OP_SERVICE_ACCOUNT_TOKEN='{{ onepasswordRead "op://3kzndqhe5bky5wj65buh2h4ybi/kpip7secen2mphnpumc4axirlm/credential" }}'
      exec bunx opencode-ai@latest "$@"
    '');
    };
    codex = {
      enable = true;
      package = (pkgs.writeShellScriptBin "codex" ''
      export OP_SERVICE_ACCOUNT_TOKEN='{{ onepasswordRead "op://3kzndqhe5bky5wj65buh2h4ybi/kpip7secen2mphnpumc4axirlm/credential" }}'
      exec bunx @openai/codex@latest "$@"
    '');
    };
    gemini-cli.enable = true;
  };
}
