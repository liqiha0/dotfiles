{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "plugin": [
    "opencode-antigravity-auth@beta",
    "oh-my-opencode@latest"
  ],
  "small_model": "google/gemini-3-flash-preview",
  "provider": {
    "google": {
      "models": {
        "antigravity-claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5 (no thinking) (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "antigravity-claude-sonnet-4-5-thinking": {
          "name": "Claude Sonnet 4.5 Thinking (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192
              }
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768
              }
            }
          }
        },
        "antigravity-claude-opus-4-5-thinking": {
          "name": "Claude Opus 4.5 Thinking (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192
              }
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768
              }
            }
          }
        }
      }
    }
  },
  "mcp": {
    "spec-workflow": {
      "type": "local",
      "command": [
        "pnpm",
        "dlx",
        "@pimzino/spec-workflow-mcp@latest"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "pnpm",
        "dlx",
        "@upstash/context7-mcp@latest"
      ]
    },
    "obsidian": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-obsidian"
      ],
      "environment": {
        "OBSIDIAN_API_KEY": "672db5afde5e4f2e94674feb9fa922446b1b890ad26cd45b6aa2cb593aa75176"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "pnpm",
        "dlx",
        "@playwright/mcp@latest",
        "--isolated"
      ]
    }
  }
}
